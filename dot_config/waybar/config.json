{
  "output": ["DP-2", "eDP-1"],
  "modules-left": ["custom/nix", "clock"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "tray",
    "cpu",
    "memory",
    "backlight",
    "pulseaudio",
    "bluetooth",
    "network",
    "battery"
  ],
  "custom/nix": {
    "format": " пМУ  ",
    "tooltip": false,
    "on-click": "sh $HOME/.config/rofi/bin/powermenu"
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "all-outputs": false
    // Uncomment and customize the icons if needed
    // "format-icons": {
    //   "1": "дЄА",
    //   "2": "дЇМ",
    //   "3": "дЄЙ",
    //   "4": "еЫЫ",
    //   "5": "дЇФ",
    //   "6": "еЕ≠",
    //   "7": "дЄГ",
    //   "8": "еЕЂ",
    //   "9": "дєЭ",
    //   "10": "еНБ"
    // }
  },
  // "custom/cava-internal": {
  //   "exec": "sleep 1s && cava-internal",
  //   "tooltip": false
  // },
  "clock": {
    "format": "<span color='#ebdbb2'>пАЧ </span>{:%H:%M}",
    "tooltip": true,
    "tooltip-format": "{:%Y-%m-%d %a}"
    // Uncomment if needed
    // "on-click-middle": "exec default_wallpaper",
    // "on-click-right": "exec wallpaper_random"
  },
  "cpu": {
    "format": "<span color='#ebdbb2'>пТЉ  </span>{usage}%"
  },
  "memory": {
    "interval": 1,
    "format": "<span color='#ebdbb2'>оЙ¶  </span>{used:0.1f}G/{total:0.1f}G"
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "<span color='#ebdbb2'>{icon}  </span> {percent}%",
    "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
  },
  "pulseaudio": {
    "format": "<span color='#ebdbb2'>{icon}  </span> {volume}%",
    "format-muted": "пА¶",
    "tooltip": false,
    "format-icons": {
      "headphone": "пА•",
      "default": ["пА¶", "пАІ", "у∞ХЊ", "у∞ХЊ", "у∞ХЊ", "пА®", "пА®", "пА®"]
    },
    "scroll-step": 1,
    "on-click": "pavucontrol"
  },
  "bluetooth": {
    "format": "<span color='#ebdbb2'>пКФ</span>",
    "format-disabled": "<span color='#ebdbb2'>пКФ</span>",
    "format-connected": "<span color='#ebdbb2'>пКФ</span> {num_connections}",
    "tooltip-format": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}   {device_address}",
    "on-click": "blueberry"
  },
  "network": {
    "format": "{ifname}",
    "format-wifi": "<span color='#ebdbb2'>пЗЂ </span>{essid}",
    "format-ethernet": "{ipaddr}/{cidr} пЮЦ",
    "format-disconnected": "<span color='#ebdbb2'>у∞Ц™ </span>No Network",
    "tooltip": false,
    "on-click": "nm-applet"
  },
  "battery": {
    "format": "<span color='#ebdbb2'>{icon}</span> {capacity}%",
    "format-icons": ["пХє", "пХЇ", "пХї", "пХЉ", "пХљ", "пХЊ", "пХњ", "пЦА", "пЦБ", "пХЄ"],
    "format-charging": "<span color='#ebdbb2'>пЦГ</span> {capacity}%",
    "tooltip": false
  },
  "tray": {
    "show-passive-items": true,
    "icon-size": 15
  },
  "sidebar": {
    "output": "DP-1",
    "modules-center": ["hyprland/workspaces"],
    "hyprland/workspaces": {
      "format": "{icon}",
      "all-outputs": false
      // Uncomment and customize the icons if needed
      // "format-icons": {
      //   "1": "дЄА",
      //   "2": "дЇМ",
      //   "3": "дЄЙ",
      //   "4": "еЫЫ",
      //   "5": "дЇФ",
      //   "6": "еЕ≠",
      //   "7": "дЄГ",
      //   "8": "еЕЂ",
      //   "9": "дєЭ",
      //   "10": "еНБ"
      // }
    }
  }
}
